# crypto-dashboard worker — environment example
#
# Copy this file to `.env.local` (gitignored) before running the worker.
# Secrets must never be committed.

# ---- Telegram delivery ----
# Required to actually send alerts. When missing the worker still runs
# and writes JSONL/state but reports `lastDeliveryStatus: disabled`.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Cycle ----
WORKER_SYMBOLS=BTCUSDT
WORKER_INTERVAL_MIN=15

# ---- Engine timeframes ----
WORKER_SETUP_TF=30m
WORKER_MACRO_TF=4h
WORKER_TRIGGER_TF=15m

# ---- Alert discipline ----
WORKER_ALERT_COOLDOWN_MIN=60
WORKER_MIN_CONFIDENCE=65
WORKER_SEND_WAIT_ALERTS=false
WORKER_SEND_HEALTH_ALERTS=true
WORKER_HEALTH_ALERTS_PER_HOUR=1

# ---- Storage ----
WORKER_DATA_DIR=./data/worker

# ---- Behavior ----
# When false, the worker exits if Telegram returns an error (useful in CI).
WORKER_CONTINUE_ON_TELEGRAM_FAILURE=true
