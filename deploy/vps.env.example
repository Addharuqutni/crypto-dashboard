# Copy to .env.local on the VPS and edit secrets.
NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1

# Recommended for VPS: local file storage. Keep Supabase empty unless you intentionally use it.
SCREENER_STORAGE_MODE=file
SCREENER_STORAGE_BACKEND=file
SCREENER_REQUIRE_DATABASE=0
SCREENER_FILE_MODE_STRICT=1
DISABLE_SCREENER_SCHEDULER=1

# Empty SCREENER_SYMBOLS uses built-in top-100 Binance USDT perpetual universe.
SCREENER_SYMBOLS=
SCREENER_MAX_SYMBOLS=100
SCREENER_MAX_CONCURRENT_SYMBOLS=3
SCREENER_CANDLE_LIMIT=120
SCREENER_API_RATE_LIMIT_PER_MINUTE=120
CRON_SECRET=change-this-long-random-secret

# Optional Basic Auth for private dashboard access.
BASIC_AUTH_ENABLED=1
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-this-long-random-password

# Optional server-side AI.
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Optional Supabase. Leave empty for VPS file mode.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Telegram worker.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WORKER_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
WORKER_INTERVAL_MIN=15
WORKER_SETUP_TF=30m
WORKER_MACRO_TF=4h
WORKER_TRIGGER_TF=15m
WORKER_ALERT_COOLDOWN_MIN=60
WORKER_MIN_CONFIDENCE=65
WORKER_SEND_WAIT_ALERTS=false
WORKER_SEND_HEALTH_ALERTS=true
WORKER_HEALTH_ALERTS_PER_HOUR=1
WORKER_DATA_DIR=./data/worker
WORKER_CONTINUE_ON_TELEGRAM_FAILURE=true
