# App runtime
# Set to 1 when the screener is run as a separate process/cron/PM2 worker.
DISABLE_SCREENER_SCHEDULER=1

# Screener runtime mode.
# Vercel/serverless: use Supabase storage + /api/cron/screener.
# Local/VPS fallback: file storage reads/writes data/screener/*.json.
SCREENER_STORAGE_MODE=file
SCREENER_STORAGE_BACKEND=supabase
SCREENER_REQUIRE_DATABASE=1
CRON_SECRET=change-this-long-random-secret
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SCREENER_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT
SCREENER_CANDLE_LIMIT=120
SCREENER_MAX_CONCURRENT_SYMBOLS=1
SCREENER_MAX_SYMBOLS=6

# Optional Basic Auth for private production deployments.
# Leave BASIC_AUTH_ENABLED unset or 0 for public dashboards.
BASIC_AUTH_ENABLED=0
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-this-long-random-password

# Optional server-side AI audit used by the screener scheduler/script.
# The browser AI settings are separate and user-provided.
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Worker / Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WORKER_SYMBOLS=BTCUSDT
WORKER_INTERVAL_MIN=15
WORKER_SETUP_TF=30m
WORKER_MACRO_TF=4h
WORKER_TRIGGER_TF=15m
WORKER_ALERT_COOLDOWN_MIN=60
WORKER_MIN_CONFIDENCE=65
WORKER_SEND_WAIT_ALERTS=false
WORKER_SEND_HEALTH_ALERTS=true
WORKER_HEALTH_ALERTS_PER_HOUR=1
WORKER_DATA_DIR=./data/worker
WORKER_CONTINUE_ON_TELEGRAM_FAILURE=true
